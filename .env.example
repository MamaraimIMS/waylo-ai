# =============================================================================
# WayloAI · Environment Variables (SAMPLE)
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями.
# .env добавлен в .gitignore, в репозиторий не попадёт.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (получите в Dashboard → Settings → API & Database)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

SUPABASE_DB_HOST=db.xxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>
SUPABASE_DB_NAME=postgres

# -----------------------------------------------------------------------------
# Anthropic Claude API (получите в console.anthropic.com)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# n8n Cloud webhook (получите после импорта workflow)
# -----------------------------------------------------------------------------
WAYLO_WEBHOOK_URL=https://xxxxx.app.n8n.cloud/webhook/waylo-intake
WAYLO_WEBHOOK_AUTH=

# -----------------------------------------------------------------------------
# Telegram Bot (опционально — для уведомлений водителям)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Frontend configuration (GitHub Pages URL после деплоя)
# -----------------------------------------------------------------------------
WAYLO_DASHBOARD_URL=https://YOUR-USERNAME.github.io/waylo-ai/dashboard/
WAYLO_DRIVER_URL=https://YOUR-USERNAME.github.io/waylo-ai/driver/
